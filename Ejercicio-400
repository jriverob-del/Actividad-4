    private void btnCalcularActionPerformed(java.awt.event.ActionEvent evt) {                                            

        try {
        JOptionPane.showMessageDialog(null, "Ingresando al primer try", "Atención", JOptionPane.INFORMATION_MESSAGE);

        double numerador = Double.parseDouble(txtNumerador.getText());
        double denominador = Double.parseDouble(txtDenominador.getText());
        double cociente = numerador/denominador;
        txtCociente.setText(String.valueOf(cociente));
   
        System.out.println("Después de la división");
        JOptionPane.showMessageDialog(null, "Despues de la división", "Atención", JOptionPane.INFORMATION_MESSAGE);
         
        } 
        catch (ArithmeticException e) { 
               JOptionPane.showMessageDialog(null, "División por cero", "Atención", JOptionPane.INFORMATION_MESSAGE);
        } 
        finally {

            JOptionPane.showMessageDialog(null, "Ingresando al primer finally", "Atención", JOptionPane.INFORMATION_MESSAGE);
        }

    try {
        JOptionPane.showMessageDialog(null, "Ingresando al segundo try", "Atención", JOptionPane.INFORMATION_MESSAGE);

        Object objeto = null;
        objeto.toString();

        JOptionPane.showMessageDialog(null, "Imprimiendo Objeto", "Atención", JOptionPane.INFORMATION_MESSAGE);

    } 
    catch (ArithmeticException e) {

        JOptionPane.showMessageDialog(null, "División por cero", "Atención", JOptionPane.INFORMATION_MESSAGE);

    } 
    catch (Exception e) {

        JOptionPane.showMessageDialog(null, "Ocurrió una excepción", "Atención", JOptionPane.INFORMATION_MESSAGE);
    } 
    finally {

        JOptionPane.showMessageDialog(null, "Ingresando al segundo finally", "Atención", JOptionPane.INFORMATION_MESSAGE);
    }
    }                                           

